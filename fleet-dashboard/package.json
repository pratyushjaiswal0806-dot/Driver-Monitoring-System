{
    "name": "fleet-dashboard",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "concurrently -k -n server,client \"npm run dev:server\" \"npm run dev:client\"",
        "dev:server": "node server/server.js",
        "dev:client": "cd client && vite --host 0.0.0.0",
        "build": "cd client && vite build",
        "preview": "cd client && vite preview --host 0.0.0.0",
        "start": "node server/server.js"
    },
    "dependencies": {
        "concurrently": "^9.1.2",
        "cors": "^2.8.5",
        "express": "^4.21.2",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-router-dom": "^7.4.1",
        "recharts": "^2.15.1"
    },
    "devDependencies": {
        "@vitejs/plugin-react": "^4.3.4",
        "autoprefixer": "^10.4.21",
        "postcss": "^8.5.3",
        "tailwindcss": "^3.4.17",
        "vite": "^6.2.3"
    }
}